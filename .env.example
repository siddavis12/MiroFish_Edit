# LLM 설정 (OpenAI API)
LLM_API_KEY=your_openai_api_key_here
LLM_MODEL_NAME=gpt-5-mini
# 지원 모델: gpt-5-mini, gpt-5-nano, gpt-4o, gpt-4o-mini, o3-mini, o4-mini 등

# ===== Neo4j 그래프 데이터베이스 설정 =====
# Docker로 실행: docker run -d --name neo4j -p 7474:7474 -p 7687:7687 -e NEO4J_AUTH=neo4j/mirofish neo4j:5-community
NEO4J_HOST=localhost
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish

# ===== Boost LLM 설정 (선택) =====
# 병렬 시뮬레이션 시 두 번째 API 서비스로 동시성 향상
# 설정하지 않으면 기본 LLM으로 폴백
# LLM_BOOST_API_KEY=your_boost_api_key_here
# LLM_BOOST_MODEL_NAME=your_boost_model_name

# ===== ChromaDB 설정 (선택) =====
# 기본값: backend/chroma_data (인프로세스 실행)
# CHROMA_PERSIST_DIR=./chroma_data
